// ~~ Generated by projen. To modify, edit .projenrc.ts and run "pnpm exec projen".
{
  "schedule": [
    "at any time"
  ],
  "extends": [
    ":preserveSemverRanges",
    "config:recommended",
    "group:allNonMajor",
    "group:recommended",
    "group:monorepos"
  ],
  "packageRules": [
    {
      "matchDepTypes": [
        "devDependencies"
